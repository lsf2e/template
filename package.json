{
  "name": "@lsf2e/template",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@11.0.9",
  "description": "A template for a new project",
  "author": "Local Services Front to End <lsf2e@bjmhe.me>",
  "license": "MIT",
  "homepage": "https://github.com/lsf2e/template#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lsf2e/template.git"
  },
  "bugs": {
    "url": "https://github.com/lsf2e/template/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "prettier --cache --write .",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "8.1.0",
    "@sxzz/prettier-config": "2.3.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "25.7.0",
    "bumpp": "11.1.0",
    "eslint": "10.4.0",
    "prettier": "3.8.3",
    "tsdown": "0.22.0",
    "tsdown-preset-sxzz": "0.6.0",
    "tsnapi": "0.3.3",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
